# Supabase — copy to .env.local and fill in from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the client. Used only by the admin invite action.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the deployed app (used to build invite redirect links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret for the daily EDM sync cron route (/api/cron/edm-sync).
# Vercel Cron must send "Authorization: Bearer ${CRON_SECRET}".
CRON_SECRET=change-me

# Branded transactional email via Resend (invites + password resets). Optional —
# if unset, the app falls back to Supabase's default email sender.
# RESEND_FROM must be a verified sending domain in your Resend account.
RESEND_API_KEY=
RESEND_FROM=River Hub <no-reply@yourdomain.org>
RESEND_REPLY_TO=
